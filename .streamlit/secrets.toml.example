# Copy this file to secrets.toml in THIS folder (never commit secrets.toml).
# Get values from: Supabase Dashboard → your project → Project Settings → API
#
#   Project URL  → SUPABASE_URL
#   anon public    → SUPABASE_PUBLISHABLE_KEY  (JWT eyJ… or sb_publishable_…)
#
# Do NOT use the service_role key for login.

SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_PUBLISHABLE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

# Optional — server-side admin operations only (never expose in client code)
# SUPABASE_SERVICE_ROLE_KEY = "your-service-role-jwt"
# SUPABASE_SECRET_KEY = "sb_secret_..."
# SUPABASE_ANON_KEY = "eyJ..."

# Optional app settings
# APP_NAME = "IPS Operations"
# LOG_LEVEL = "INFO"
