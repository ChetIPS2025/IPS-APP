# Copy to .env or map the same keys in .streamlit/secrets.toml (gitignored).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional — server-side admin (invites, storage); never expose in the browser
# SUPABASE_SERVICE_ROLE_KEY=

APP_BASE_URL=http://localhost:8501
LOG_LEVEL=INFO

# Optional — Quick Add Tool AI (photo scan, receipt OCR, image match)
# Provider currently supported: openai (falls back to OPENAI_API_KEY when TOOL_*_API_KEY is unset)
# TOOL_VISION_PROVIDER=openai
# TOOL_VISION_API_KEY=
# TOOL_OCR_PROVIDER=openai
# TOOL_OCR_API_KEY=
# TOOL_IMAGE_SEARCH_PROVIDER=openai
# TOOL_IMAGE_SEARCH_API_KEY=

# Optional — legacy asset photo autofill (also used as fallback for tool AI keys above)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
